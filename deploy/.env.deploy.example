# ── Required: copy this file to .env.deploy and fill in all values ──────────
# Run deploy/setup.sh ONCE, then push to the `deploy` branch.
# All data services (MongoDB, Redis, RabbitMQ) run as Docker containers
# on a single Compute Engine VM inside the same VPC — no external accounts needed.

# ── GCP project ─────────────────────────────────────────────────────────────
GCP_PROJECT=your-gcp-project-id
GCP_REGION=us-central1
AR_REPO=whatsapp-mate

# ── VM data-service credentials ──────────────────────────────────────────────
# RabbitMQ password for the 'wm' user (choose a strong password)
RABBITMQ_PASSWORD=change-me-strong-password

# ── VPC / networking ─────────────────────────────────────────────────────────
# These are auto-created by setup.sh — leave as-is unless you have a custom VPC
VPC_NETWORK=wm-vpc
VPC_SUBNET=wm-subnet
VPC_SUBNET_RANGE=10.100.0.0/28
VPC_CONNECTOR=wm-connector
